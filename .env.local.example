# Lejel Backend (sesuai backend doc)
# Base URL backend (tanpa trailing slash)
NEXT_PUBLIC_LEJEL_API_URL=https://lejel-backend.richardtandean.my.id
# Fallback jika tidak pakai LEJEL:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# API key untuk OAuth/YouTube (create connection, disconnect, upload)
# Wajib jika pakai fitur YouTube connection & upload
NEXT_PUBLIC_LEJEL_API_KEY=

# Kosongkan NEXT_PUBLIC_LEJEL_API_URL untuk mock auth (login: user123@gmail.com / password123)

# Key untuk menyimpan access token di localStorage (opsional)
# NEXT_PUBLIC_AUTH_TOKEN_KEY=lejel_access_token
